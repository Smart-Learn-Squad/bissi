{
  "name": "bissi-master",
  "version": "1.0.0",
  "description": "BISSI - Your local AI assistant desktop application",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "keywords": ["ai", "assistant", "electron", "desktop", "offline"],
  "author": "BISSI Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "mammoth": "^1.6.0",
    "xlsx": "^0.18.5",
    "pdfjs-dist": "^3.11.174"
  },
  "build": {
    "appId": "com.bissi.master",
    "productName": "BISSI Master",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
